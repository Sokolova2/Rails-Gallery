{
  "name": "app",
  "private": "true",
  "scripts": {
    "build:css:compile": "sass --no-source-map --load-path=node_modules ./app/assets/stylesheets/application.bootstrap.scss:./app/assets/builds/application.css && sass --no-source-map --load-path=node_modules --load-path=/var/lib/gems/3.2.0/gems/activeadmin-3.3.0/app/assets/stylesheets ./app/assets/stylesheets/active_admin.scss:./app/assets/builds/active_admin.css",
    "build:css:prefix": "postcss ./app/assets/builds/application.css --use=autoprefixer --output=./app/assets/builds/application.css",
    "build:css": "yarn build:css:compile && yarn build:css:prefix",
    "watch:css": "nodemon --watch ./app/assets/stylesheets/ --ext scss --exec \"yarn build:css\""
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.4.21",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "jquery": "^3.7.1",
    "masonry-layout": "^4.2.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sass": "^1.89.2",
    "yarn": "^1.22.22"
  }
}
