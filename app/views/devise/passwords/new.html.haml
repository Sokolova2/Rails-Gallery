=render 'devise/navbar'
.container
  .form-action
    .form_authenticated.p-3
      = form_for(resource, as: resource_name, url: password_path(resource_name), html: { class: "px-4 py-3 my-box mx-auto", method: :post }) do |f|
        %h2.text-center.m-3.h3.fw-bolder  Forgot your password?
        = render "devise/shared/error_messages", resource: resource
        .mb-3
          .field
            = f.label :email
            %br/
            = f.email_field :email, :class => "form-control", :id => "exampleDropdownFormEmail1", :placeholder => "name@example.com", autocomplete: "email"
        .actions.d-flex.justify-content-center
          = f.submit "Send me", class: "btn btn-primary btn-authenticated"
        %br/
        .d-flex.justify-content-center.gap-1
          %p Remember your password?
          = render "devise/shared/links_for_log_in"
