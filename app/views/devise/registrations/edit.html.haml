=render 'categories/navbar'
.container
  .d-flex.justify-content-between.align-items-center.mt-3
    %h2.text-start.m-3.h3.fw-bold Edit
    =button_to "Cancel my account", registration_path(resource_name), class: "btn btn-outline-dark", data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete
  = form_for(resource, as: resource_name, url: registration_path(resource_name), html: {class: "px-4 py-3 my-box mx-auto", method: :put, multipart:true }) do |f|
    = render "devise/shared/error_messages", resource: resource
    .d-flex.justify-content-center
      -if @user.avatar.present?
        =image_tag @user.avatar.url, size: 200, class: "rounded-circle"
      -else
        =image_tag "avatar.png", size: 200, class: "rounded-circle"
    .mb-3
      .field
        .mt-2
          %label{ for: "image_upload", class: "custom-upload-label btn btn-outline-secondary" } Upload avatar
          = f.file_field :avatar, id: "image_upload", class: "d-none"
          %br/
    .mb-3
      .field
        = f.label :first_name
        %br/
        = f.text_field :first_name, :class => "form-control", autofocus: true, autocomplete: "first_name"
    .mb-3
      .field
        = f.label :last_name
        %br/
        = f.text_field :last_name, :class => "form-control", autofocus: true, autocomplete: "last_name"
    .mb-3
      .field
        = f.label :email
        %br/
        = f.email_field :email, :class => "form-control", autofocus: true, autocomplete: "email"
    - if devise_mapping.confirmable? && resource.pending_reconfirmation?
      %div
        Currently waiting confirmation for: #{resource.unconfirmed_email}
    .mb-3
      .field
        = f.label :password
        - if @minimum_password_length
          %br/
          %em
            = @minimum_password_length
            characters minimum
        %br/
        = f.password_field :password, :class => "form-control",  autocomplete: "new-password"
    .mb-3
      .field
        = f.label :password_confirmation
        %br/
        = f.password_field :password_confirmation, :class => "form-control", autocomplete: "new-password"
    .mb-3
      .field
        = f.label :current_password
        %br/
        = f.password_field :current_password, :class => "form-control", autocomplete: "current-password"
    .actions.d-flex.justify-content-center
      = f.submit "Update", class: "btn btn-dark btn-authenticated"