%nav.navbar.justify-content-between.p-3
  %div.d-flex.gap-5
    %h1.navbar-brand.name-brand.text-light Gallery
    %div.d-flex.align-items-center.gap-3
      = button_to "Home", root_path, method: :get, class: "btn btn-outline-dark text-light"
      = button_to "Categories", categories_path, method: :get,class: "btn btn-outline-dark text-light"
  -if user_signed_in?
    .dropdown.pe-2
      %button.btn.btn-outline-secondary.dropdown-toggle{"aria-expanded" => "false", "data-bs-toggle" => "dropdown", :type => "button"}
        = user_signed_in? ? "#{current_user.first_name} #{current_user.last_name}" : ""
        - if user_signed_in?
          = image_tag current_user.avatar.url(:thumb), with: 50, height: 50, style: "border-radius:1px"
      %ul.btn.dropdown-menu
        %li.dropdown-item
          = button_to("Sign out", destroy_user_session_path, method: :delete, class: "btn w-100")
          = button_to("Sign out", destroy_user_session_path, method: :delete, class: "btn w-100")

  -unless user_signed_in?
    .d-flex.pe-2.gap-3
      = button_to("Sign In", new_user_session_path, method: :get, class:"btn btn-secondary p-3")
      = button_to("Create Account", new_user_registration_path, method: :get, class:"btn btn-light p-3")