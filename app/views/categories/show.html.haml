= render "categories/navbar"
.container.mt-5
  .d-flex.justify-content-between.align-items-center
    %h1.h2= @category.category_name

    =form_with(model: [@category, Image.new], local: true, html: {multipart: true, id: "image-upload-form"}, data: {turbo_frame: "frame2" }) do |f|
      .mb-3
        %div
          .mt-2
            %label{ for: "image_upload", class: "custom-upload-label btn btn-secondary btn-upload" } Upload
            = f.file_field :image, id: "image_upload", class: "d-none"
            %br/
      .d-flex.justify-content-between.mt-1
        =f.submit "Upload", class: "btn btn-primary mt-2 d-flex justify-content-center d-none"
  .mt-5
    .grid
      -@category.images.each do |img|
        =link_to category_image_path(@category, img) do
          =image_tag img.image.url(:thumb), class: "rounded-3"
