= render "categories/navbar"
.container.d-flex.justify-content-between.mt-4.align-items-center.mb-5
  %h2.h2= t(".subscriptions")
.container.d-flex.gap-5.flex-wrap
  -@categories.each do |category|
    -category.subscribers.each do |subscriber|
      -if subscriber.user.id == current_user.id
        %div
          =link_to category_path(category), class: "text-decoration-none text-black" do
            .img-wrapper
              =preview_category(category)
          .d-flex.justify-content-between.align-items-end
            %p.h5.text-dark.align-items-center= category.category_name
            =button_to "Unsubscribe", category_subscriber_path(category, current_user.id), method: :delete, class: "btn btn-outline-secondary p-2"
.container.d-flex.justify-content-center.mt-5
  =paginate @categories